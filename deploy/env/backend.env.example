APP_NAME=surebet-platform
APP_ENV=development
AUTH_TOKEN_SECRET=surebet-dev-secret-change-me
AUTH_TOKEN_TTL=12h
HTTP_ADDRESS=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_PREFETCH=32
RABBITMQ_EXCHANGE=surebet.domain
REDIS_ADDRESS=localhost:6379
REDIS_DB=0
REDIS_PASSWORD=
POSTGRES_DSN=postgres://surebet:surebet@localhost:5432/surebet?sslmode=disable
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_REQUEST_TIMEOUT=10s
TELEGRAM_SUREBET_DEDUP_WINDOW=30m
TELEGRAM_SUREBET_SCAN_COOLDOWN=5s
AUTO_BET=false
MANUAL_CONFIRMATION=true
RISK_VALIDATION=true
MAX_STAKE_CHECK=true
BALANCE_CHECK=true
ODDS_RECHECK=true
LIQUIDITY_CHECK=true
BOOKMAKER_ENABLE=true
