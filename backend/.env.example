APP_NAME=surebet-platform
APP_ENV=development

AUTH_TOKEN_SECRET=surebet-dev-secret-change-me
AUTH_TOKEN_TTL=12h

HTTP_ADDRESS=:8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s

POSTGRES_DSN=postgres://surebet:surebet@127.0.0.1:5432/surebet?sslmode=disable

# Optional: Telegram surebet notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_REQUEST_TIMEOUT=10s
TELEGRAM_SUREBET_DEDUP_WINDOW=30m
TELEGRAM_SUREBET_SCAN_COOLDOWN=5s
TELEGRAM_QUEUE_POLL_INTERVAL=2s
TELEGRAM_QUEUE_BATCH_SIZE=25
TELEGRAM_QUEUE_MAX_ATTEMPTS=5
TELEGRAM_QUEUE_RETRY_DELAY=30s
